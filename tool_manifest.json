{
  "$schema": "https://modelcontextprotocol.io/schemas/tool-manifest.json",
  "name": "ds-interview-prep-mcp",
  "version": "1.0.0",
  "description": "MCP server for Data Science Analytical Interview Preparation Handbook - provides AI-enhanced tools for learning, quiz generation, SQL validation, and content creation.",
  "author": "DS Interview Prep Team",
  "license": "MIT",
  "repository": "https://github.com/your-org/ds-interview-prep-mcp",
  "tools": [
    {
      "name": "generate_quiz_question",
      "description": "Generate a multiple-choice quiz question for data science interview prep covering statistics, SQL, Python, or A/B testing topics.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string",
            "enum": ["sql_basics", "python_data_analysis", "statistics_probability", "ab_testing", "product_metrics", "case_studies"],
            "description": "The topic category for the question"
          },
          "difficulty": {
            "type": "string",
            "enum": ["beginner", "intermediate", "advanced"],
            "description": "Difficulty level of the question"
          },
          "subtopic": {
            "type": "string",
            "description": "Optional specific subtopic (e.g., 'window_functions', 'hypothesis_testing')"
          },
          "context": {
            "type": "string",
            "description": "Optional real-world context for the question (e.g., 'social media engagement metrics')"
          }
        },
        "required": ["topic", "difficulty"]
      }
    },
    {
      "name": "grade_quiz_response",
      "description": "Evaluate a user's quiz answer and provide feedback.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "question_id": {
            "type": "string",
            "description": "Unique identifier for the question"
          },
          "question_text": {
            "type": "string",
            "description": "The quiz question text"
          },
          "options": {
            "type": "array",
            "items": { "type": "string" },
            "description": "The answer options"
          },
          "correct_index": {
            "type": "integer",
            "description": "Index of the correct answer (0-based)"
          },
          "selected_index": {
            "type": "integer",
            "description": "Index of the user's selected answer (0-based)"
          }
        },
        "required": ["question_text", "options", "correct_index", "selected_index"]
      }
    },
    {
      "name": "explain_quiz_answer",
      "description": "Provide a detailed explanation for a quiz question answer.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "description": "The quiz question"
          },
          "options": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Answer options"
          },
          "correct_index": {
            "type": "integer",
            "description": "Index of correct answer"
          },
          "depth": {
            "type": "string",
            "enum": ["brief", "standard", "comprehensive"],
            "default": "standard",
            "description": "How detailed the explanation should be"
          }
        },
        "required": ["question", "options", "correct_index"]
      }
    },
    {
      "name": "get_quiz_by_topic",
      "description": "Retrieve existing quiz questions from the handbook's quiz database.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string",
            "enum": ["sql_basics", "python_data_analysis", "statistics_probability", "ab_testing"],
            "description": "Quiz topic to retrieve"
          },
          "limit": {
            "type": "integer",
            "default": 5,
            "description": "Maximum number of questions to return"
          },
          "shuffle": {
            "type": "boolean",
            "default": true,
            "description": "Randomize question order"
          }
        },
        "required": ["topic"]
      }
    },
    {
      "name": "validate_sql_query",
      "description": "Validate SQL query syntax and check for common errors, anti-patterns, and potential performance issues.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "The SQL query to validate"
          },
          "dialect": {
            "type": "string",
            "enum": ["postgresql", "mysql", "sqlite", "bigquery", "snowflake"],
            "default": "postgresql",
            "description": "SQL dialect to validate against"
          },
          "schema_context": {
            "type": "object",
            "description": "Optional table schema for semantic validation",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "column": { "type": "string" },
                  "type": { "type": "string" }
                }
              }
            }
          },
          "check_performance": {
            "type": "boolean",
            "default": false,
            "description": "Include performance analysis"
          }
        },
        "required": ["query"]
      }
    },
    {
      "name": "explain_sql_query",
      "description": "Explain what a SQL query does, step by step, in plain language.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "The SQL query to explain"
          },
          "detail_level": {
            "type": "string",
            "enum": ["beginner", "intermediate", "advanced"],
            "default": "intermediate",
            "description": "Level of technical detail in explanation"
          },
          "include_execution_order": {
            "type": "boolean",
            "default": true,
            "description": "Include SQL execution order explanation"
          }
        },
        "required": ["query"]
      }
    },
    {
      "name": "generate_sql_problem",
      "description": "Generate a SQL practice problem with table schemas and expected output.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "difficulty": {
            "type": "string",
            "enum": ["easy", "medium", "hard"],
            "description": "Problem difficulty"
          },
          "topics": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["joins", "aggregations", "window_functions", "subqueries", "ctes", "self_joins", "date_functions", "string_functions"]
            },
            "description": "SQL concepts to include"
          },
          "domain": {
            "type": "string",
            "enum": ["social_media", "ecommerce", "fintech", "healthcare", "generic"],
            "default": "social_media",
            "description": "Business domain context"
          },
          "include_solution": {
            "type": "boolean",
            "default": false,
            "description": "Include the solution"
          },
          "include_hints": {
            "type": "boolean",
            "default": true,
            "description": "Include hints"
          }
        },
        "required": ["difficulty", "topics"]
      }
    },
    {
      "name": "optimize_sql_query",
      "description": "Analyze a SQL query and suggest performance optimizations.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "The SQL query to optimize"
          },
          "table_sizes": {
            "type": "object",
            "description": "Approximate row counts for tables",
            "additionalProperties": { "type": "integer" }
          },
          "existing_indexes": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of existing indexes"
          }
        },
        "required": ["query"]
      }
    },
    {
      "name": "generate_stats_problem",
      "description": "Generate a statistics or probability practice problem.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string",
            "enum": ["descriptive_stats", "probability", "hypothesis_testing", "confidence_intervals", "distributions", "regression", "bayesian"],
            "description": "Statistics topic"
          },
          "difficulty": {
            "type": "string",
            "enum": ["beginner", "intermediate", "advanced"],
            "description": "Problem difficulty"
          },
          "context": {
            "type": "string",
            "description": "Real-world context (e.g., 'A/B testing at Meta')"
          },
          "include_solution": {
            "type": "boolean",
            "default": false
          }
        },
        "required": ["topic", "difficulty"]
      }
    },
    {
      "name": "calculate_sample_size",
      "description": "Calculate required sample size for an A/B test or survey.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "metric_type": {
            "type": "string",
            "enum": ["proportion", "mean"],
            "description": "Type of metric"
          },
          "baseline_value": {
            "type": "number",
            "description": "Current baseline value"
          },
          "minimum_detectable_effect": {
            "type": "number",
            "description": "Minimum relative lift to detect (e.g., 0.05 for 5%)"
          },
          "standard_deviation": {
            "type": "number",
            "description": "Standard deviation (required for mean metrics)"
          },
          "alpha": {
            "type": "number",
            "default": 0.05,
            "description": "Significance level"
          },
          "power": {
            "type": "number",
            "default": 0.8,
            "description": "Statistical power"
          },
          "sides": {
            "type": "string",
            "enum": ["one", "two"],
            "default": "two",
            "description": "One-sided or two-sided test"
          }
        },
        "required": ["metric_type", "baseline_value", "minimum_detectable_effect"]
      }
    },
    {
      "name": "design_ab_experiment",
      "description": "Help design a complete A/B test experiment with metrics, sample size, and analysis plan.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "hypothesis": {
            "type": "string",
            "description": "The hypothesis to test"
          },
          "primary_metric": {
            "type": "string",
            "description": "The primary success metric"
          },
          "baseline_rate": {
            "type": "number",
            "description": "Current baseline rate"
          },
          "minimum_detectable_effect": {
            "type": "number",
            "description": "Minimum relative lift to detect"
          },
          "daily_traffic": {
            "type": "integer",
            "description": "Daily eligible users/sessions"
          },
          "significance_level": {
            "type": "number",
            "default": 0.05
          },
          "power": {
            "type": "number",
            "default": 0.8
          },
          "guardrail_metrics": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["hypothesis", "primary_metric", "baseline_rate", "minimum_detectable_effect"]
      }
    },
    {
      "name": "analyze_ab_results",
      "description": "Analyze A/B test results and provide statistical interpretation.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "control_conversions": {
            "type": "integer",
            "description": "Number of conversions in control"
          },
          "control_total": {
            "type": "integer",
            "description": "Total users in control"
          },
          "treatment_conversions": {
            "type": "integer",
            "description": "Number of conversions in treatment"
          },
          "treatment_total": {
            "type": "integer",
            "description": "Total users in treatment"
          },
          "metric_type": {
            "type": "string",
            "enum": ["proportion", "mean"],
            "default": "proportion"
          },
          "control_mean": { "type": "number" },
          "treatment_mean": { "type": "number" },
          "control_std": { "type": "number" },
          "treatment_std": { "type": "number" }
        },
        "required": ["control_total", "treatment_total"]
      }
    },
    {
      "name": "generate_ab_scenario",
      "description": "Generate an A/B testing interview scenario with questions.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "company_type": {
            "type": "string",
            "enum": ["social_media", "ecommerce", "fintech", "streaming", "marketplace"],
            "description": "Company type for context"
          },
          "scenario_type": {
            "type": "string",
            "enum": ["design", "analysis", "debugging", "decision"],
            "description": "Focus of the scenario"
          },
          "difficulty": {
            "type": "string",
            "enum": ["junior", "mid", "senior"],
            "description": "Interview level"
          },
          "include_data": {
            "type": "boolean",
            "default": true,
            "description": "Include sample data"
          }
        },
        "required": ["company_type", "scenario_type", "difficulty"]
      }
    },
    {
      "name": "detect_ab_pitfalls",
      "description": "Analyze an A/B test design for common pitfalls and mistakes.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "experiment_description": {
            "type": "string",
            "description": "Description of the experiment design"
          },
          "randomization_unit": {
            "type": "string",
            "description": "Unit of randomization"
          },
          "metrics": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Metrics being tracked"
          },
          "duration_days": {
            "type": "integer",
            "description": "Planned duration"
          },
          "traffic_percentage": {
            "type": "number",
            "description": "Percentage of traffic in experiment"
          }
        },
        "required": ["experiment_description"]
      }
    },
    {
      "name": "generate_case_study",
      "description": "Generate a product analytics case study for interview practice.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "domain": {
            "type": "string",
            "enum": ["social_media", "ecommerce", "fintech", "streaming", "marketplace", "saas"],
            "description": "Industry domain"
          },
          "focus_area": {
            "type": "string",
            "enum": ["metrics_definition", "product_launch", "feature_evaluation", "user_growth", "monetization", "retention"],
            "description": "Primary focus"
          },
          "difficulty": {
            "type": "string",
            "enum": ["entry_level", "mid_level", "senior"],
            "description": "Target level"
          },
          "time_allocation": {
            "type": "integer",
            "default": 45,
            "description": "Expected time in minutes"
          },
          "include_sample_solution": {
            "type": "boolean",
            "default": false
          }
        },
        "required": ["domain", "focus_area", "difficulty"]
      }
    },
    {
      "name": "generate_behavioral_question",
      "description": "Generate a behavioral interview question for data science roles.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "competency": {
            "type": "string",
            "enum": ["leadership", "collaboration", "problem_solving", "communication", "handling_ambiguity", "impact", "growth_mindset"],
            "description": "Competency to assess"
          },
          "company_context": {
            "type": "string",
            "enum": ["meta", "google", "amazon", "netflix", "startup", "generic"],
            "default": "generic"
          },
          "include_follow_ups": {
            "type": "boolean",
            "default": true,
            "description": "Include follow-up questions"
          }
        },
        "required": ["competency"]
      }
    },
    {
      "name": "review_analytics_code",
      "description": "Review Python analytics code for best practices, performance, and correctness.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "The Python code to review"
          },
          "context": {
            "type": "string",
            "description": "What the code should accomplish"
          },
          "review_focus": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["correctness", "performance", "readability", "best_practices", "pandas_idioms", "statistical_validity"]
            },
            "default": ["correctness", "best_practices"]
          }
        },
        "required": ["code"]
      }
    },
    {
      "name": "generate_handbook_section",
      "description": "Generate content for a new handbook section in Jekyll-compatible format.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string",
            "description": "Topic for the section"
          },
          "section_type": {
            "type": "string",
            "enum": ["concept_explanation", "tutorial", "cheat_sheet", "practice_problems", "interview_guide"],
            "description": "Type of content"
          },
          "difficulty": {
            "type": "string",
            "enum": ["beginner", "intermediate", "advanced"]
          },
          "estimated_reading_time": {
            "type": "integer",
            "description": "Target reading time in minutes"
          },
          "include_examples": {
            "type": "boolean",
            "default": true
          },
          "include_practice_questions": {
            "type": "boolean",
            "default": true
          }
        },
        "required": ["topic", "section_type", "difficulty"]
      }
    },
    {
      "name": "update_quiz_yaml",
      "description": "Generate YAML content for adding new questions to quizzes.yml.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "topic": {
            "type": "string",
            "enum": ["sql_basics", "python_data_analysis", "statistics_probability", "ab_testing"],
            "description": "Quiz topic"
          },
          "questions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "question": { "type": "string" },
                "options": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "correct": { "type": "integer" },
                "explanation": { "type": "string" }
              },
              "required": ["question", "options", "correct", "explanation"]
            },
            "description": "Questions to add"
          }
        },
        "required": ["topic", "questions"]
      }
    },
    {
      "name": "create_project_scaffold",
      "description": "Create a scaffold for a new hands-on analytics project.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "project_type": {
            "type": "string",
            "enum": ["ab_test", "cohort_analysis", "churn_prediction", "demand_forecasting", "funnel_analysis", "segmentation"],
            "description": "Type of analytics project"
          },
          "project_name": {
            "type": "string",
            "description": "Name for the project"
          },
          "include_sample_data": {
            "type": "boolean",
            "default": true
          },
          "include_solution_notebook": {
            "type": "boolean",
            "default": false
          }
        },
        "required": ["project_type", "project_name"]
      }
    }
  ],
  "resources": [
    {
      "uri": "quiz://topics",
      "name": "Available Quiz Topics",
      "description": "List of all available quiz topics and their question counts"
    },
    {
      "uri": "handbook://pages",
      "name": "Handbook Pages",
      "description": "Index of all handbook pages and their metadata"
    },
    {
      "uri": "projects://list",
      "name": "Hands-On Projects",
      "description": "List of available hands-on analytics projects"
    }
  ],
  "prompts": [
    {
      "name": "interview_prep_session",
      "description": "Start an interactive interview preparation session",
      "arguments": [
        {
          "name": "focus_area",
          "description": "Area to focus on (sql, statistics, ab_testing, case_study, behavioral)",
          "required": true
        },
        {
          "name": "duration_minutes",
          "description": "Session duration",
          "required": false
        }
      ]
    },
    {
      "name": "daily_practice",
      "description": "Generate a daily practice set covering multiple topics",
      "arguments": [
        {
          "name": "difficulty",
          "description": "Overall difficulty level",
          "required": false
        }
      ]
    }
  ]
}
